    <item name="clock_size_percent" format="float" type="dimen">0.14</item>
    <item name="change_size_percent" format="float" type="dimen">0.15</item>

    <!-- Aspect ratio thresholds -->
    <item name="tablet_max_aspect_ratio" format="float" type="dimen">1.6</item>
    <item name="wide_max_aspect_ratio" format="float" type="dimen">1.9</item>

