    <dimen name="currency_text_size">70sp</dimen>
    <dimen name="change_text_size">15sp</dimen>
    <dimen name="update_text_size">3sp</dimen>
    <dimen name="padding_standard">16dp</dimen>

    <!-- Viewport-based heights (approximate, actual are calculated in code) -->
