<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/homepage_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp">

        <!-- BTC Logo SVG -->
        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/btc_logo_circle"
            android:layout_marginBottom="24dp" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="E-ink Bitcoin Price Checker"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/title_color"
            android:letterSpacing="-0.02"
            android:layout_marginBottom="8dp" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Live BTC prices from Coinbase. Data refreshes every 30 seconds."
            android:textSize="16sp"
            android:textColor="@color/subtitle_color"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <!-- Description -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="A lightweight app that displays the current Bitcoin price in USD or EUR. Designed for e-ink readers and mobile devices with a clean, minimalist interface."
            android:textSize="14sp"
            android:textColor="@color/description_color"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:maxWidth="440dp"
            android:layout_marginBottom="40dp" />

        <!-- Section Label: Select currency -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SELECT CURRENCY"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/section_label_color"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:layout_marginBottom="16dp" />

    <!-- Currency Grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="32dp">

        <!-- USD Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/usdCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_border_usd"
            app:strokeWidth="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="24dp"
                    android:paddingBottom="16dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$"
                android:textSize="48sp"
                android:textStyle="bold"
                android:textColor="@color/usd_symbol_color"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="US Dollar"
                android:textSize="12sp"
                android:textColor="#000000" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        <!-- EUR Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/eurCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_border_eur"
            app:strokeWidth="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="24dp"
                    android:paddingBottom="16dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="€"
                android:textSize="48sp"
                android:textStyle="bold"
                android:textColor="@color/eur_symbol_color"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Euro"
                android:textSize="12sp"
                android:textColor="#000000" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

    <!-- Divider with "or" -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="32dp">

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="@color/page_border" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="or"
            android:textSize="11sp"
            android:textColor="@color/section_label_color"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="@color/page_border" />
    </LinearLayout>

        <!-- Section Label: Night mode -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NIGHT MODE"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/section_label_color"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:layout_marginBottom="16dp" />

    <!-- Night mode links -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="48dp">

        <TextView
            android:id="@+id/nightUsdLink"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="USD"
            android:textSize="13sp"
            android:textColor="@color/night_link_text"
            android:background="@drawable/night_link_bg"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/nightEurLink"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EUR"
            android:textSize="13sp"
            android:textColor="@color/night_link_text"
            android:background="@drawable/night_link_bg"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp" />
    </LinearLayout>

        <!-- Footer -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Optimized for e-ink displays · Source: Coinbase API"
            android:textSize="10sp"
            android:textColor="@color/footer_color"
            android:gravity="center"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>
</ScrollView>