<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/priceRootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/price_day_bg">

    <!-- Orange border for day mode (applied programmatically) -->
    <View
        android:id="@+id/borderView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/day_border"
        android:visibility="gone" />

    <!-- Main content container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="0dp">

        <!-- Header Section - 15vh: Clock with icon -->
        <LinearLayout
            android:id="@+id/clockBlock"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="15"
            android:orientation="horizontal"
            android:gravity="end|center_vertical"
            android:paddingTop="5dp"
            android:paddingEnd="16dp"
            android:paddingStart="0dp">

            <TextView
                android:id="@+id/clockTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🕑00:00"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/abril_fatface"
                android:textColor="@color/clock_day_color"
                android:includeFontPadding="false"
                android:lineSpacingMultiplier="0.8" />

        </LinearLayout>

        <!-- BTC Text Section - 15vh: Logo -->
        <LinearLayout
            android:id="@+id/btcTextBlock"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="15"
            android:orientation="horizontal"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="0dp">

            <ImageView
                android:id="@+id/btcText"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:src="@drawable/btc_text_logo"
                android:adjustViewBounds="true"
                android:scaleType="fitStart" />

        </LinearLayout>

        <!-- Price Container - 70vh (85vh on wide screens) -->
        <FrameLayout
            android:id="@+id/priceContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="70">

            <!-- Price display with currency on same line -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <!-- Price number - dynamically sized -->
                <TextView
                    android:id="@+id/priceTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textStyle="bold"
                    android:fontFamily="@font/abril_fatface"
                    android:textColor="@color/price_day_color"
                    android:includeFontPadding="false"
                    android:singleLine="true" />

                <!-- Currency symbol -->
                <TextView
                    android:id="@+id/currencyTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$"
                    android:textStyle="bold"
                    android:fontFamily="@font/abril_fatface"
                    android:textColor="@color/currency_day_color"
                    android:includeFontPadding="false"
                    android:singleLine="true" />

            </LinearLayout>

        </FrameLayout>

        <!-- Price Change Section - 17vh -->
        <LinearLayout
            android:id="@+id/changeBlock"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="17"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- Price change value with arrow -->
            <TextView
                android:id="@+id/changeTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="▲0$"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/abril_fatface"
                android:gravity="center"
                android:singleLine="true" />

            <!-- Percentage change with arrow -->
            <TextView
                android:id="@+id/changePercentageTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="▲0.00%"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/abril_fatface"
                android:gravity="center"
                android:singleLine="true" />

        </LinearLayout>

        <!-- Last Update Section - 4vh -->
        <LinearLayout
            android:id="@+id/lastUpdateBlock"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="4"
            android:orientation="horizontal"
            android:gravity="end|center_vertical"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/lastUpdateTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last price info: 00:00:00 CET"
                android:textSize="3sp"
                android:textColor="@color/last_update_day"
                android:fontFamily="sans-serif"
                android:includeFontPadding="false" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
